<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>어드민 | Seoyeon Tour</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@300;400;500;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Noto Sans KR', sans-serif; background: #f4f5f7; }
        .sidebar {
            width: 240px;
            height: 100vh;
            background: #1a1a2e;
            position: fixed;
            top: 0; left: 0;
            padding: 32px 20px;
            color: #fff;
        }
        .sidebar .brand {
            font-size: 1rem;
            font-weight: 700;
            letter-spacing: 2px;
            margin-bottom: 40px;
            color: #fff;
        }
        .sidebar .nav-link {
            color: rgba(255,255,255,0.6) !important;
            font-size: 0.88rem;
            padding: 10px 12px;
            border-radius: 8px;
            margin-bottom: 4px;
            transition: all 0.2s;
        }
        .sidebar .nav-link:hover,
        .sidebar .nav-link.active {
            background: rgba(255,255,255,0.1);
            color: #fff !important;
        }
        .main-content {
            margin-left: 240px;
            padding: 40px;
        }
        .section-card {
            background: #fff;
            border-radius: 16px;
            padding: 28px;
            margin-bottom: 32px;
            box-shadow: 0 2px 12px rgba(0,0,0,0.06);
        }
        .section-title {
            font-size: 1rem;
            font-weight: 700;
            color: #1a1a2e;
            margin-bottom: 20px;
            padding-bottom: 12px;
            border-bottom: 1px solid #eee;
        }
        .table th {
            font-size: 0.78rem;
            color: #aaa;
            font-weight: 500;
            border-bottom: 1px solid #eee;
        }
        .table td {
            font-size: 0.85rem;
            color: #444;
            vertical-align: middle;
        }
        .btn-sm { font-size: 0.78rem; }
        .form-label { font-size: 0.82rem; color: #666; }
        .form-control, .form-select { font-size: 0.85rem; }
        .badge-admin { background: #1a1a2e; color: #fff; font-size: 0.72rem; padding: 3px 8px; border-radius: 20px; }
        .badge-user { background: #eee; color: #666; font-size: 0.72rem; padding: 3px 8px; border-radius: 20px; }
    </style>
</head>
<body>

    <div class="sidebar">
        <div class="brand">SEOYEON ADMIN</div>
        <nav class="nav flex-column">
            <a class="nav-link active" href="#products">상품 관리</a>
            <a class="nav-link" href="#events">이벤트 관리</a>
            <a class="nav-link" href="#users">회원 관리</a>
            <hr style="border-color: rgba(255,255,255,0.1); margin: 20px 0;">
            <a class="nav-link" href="/">홈으로</a>
            <a class="nav-link text-danger" href="/auth/logout" style="color: rgba(255,100,100,0.8) !important;">로그아웃</a>
        </nav>
    </div>

    <div class="main-content">

        <div class="d-flex align-items-center mb-4">
            <div>
                <p class="text-muted small mb-0">안녕하세요, <%= user.name %>님</p>
                <h4 class="fw-bold mb-0">관리자 대시보드</h4>
            </div>
        </div>

        <!-- 상품 관리 -->
        <div class="section-card" id="products">
            <div class="section-title">상품 관리</div>

            <!-- 상품 추가 폼 -->
            <form action="/admin/product/add" method="POST" class="row g-2 mb-4">
                <div class="col-md-2">
                    <select name="category" class="form-select" required>
                        <option value="">카테고리</option>
                        <option value="honeymoon-europe">허니문-유럽</option>
                        <option value="honeymoon-resort">허니문-휴양지</option>
                        <option value="group">단체여행</option>
                        <option value="package">패키지</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <input type="text" name="product_name" class="form-control" placeholder="상품명" required>
                </div>
                <div class="col-md-1">
                    <input type="number" name="price" class="form-control" placeholder="가격" required>
                </div>
                <div class="col-md-2">
                    <input type="text" name="destination" class="form-control" placeholder="여행지" required>
                </div>
                <div class="col-md-1">
                    <input type="text" name="duration" class="form-control" placeholder="기간" required>
                </div>
                <div class="col-md-2">
                    <input type="text" name="image" class="form-control" placeholder="이미지 파일명" required>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-dark btn-sm w-100">추가</button>
                </div>
            </form>

            <!-- 상품 목록 -->
            <table class="table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>카테고리</th>
                        <th>상품명</th>
                        <th>가격</th>
                        <th>여행지</th>
                        <th>기간</th>
                        <th>이미지</th>
                        <th>관리</th>
                    </tr>
                </thead>
                <tbody>
                    <% products.forEach(product => { %>
                    <tr>
                        <td><%= product.product_id %></td>
                        <td><%= product.category %></td>
                        <td><%= product.product_name %></td>
                        <td><%= Number(product.price).toLocaleString() %>원</td>
                        <td><%= product.destination %></td>
                        <td><%= product.duration %></td>
                        <td><%= product.image %></td>
                        <td>
                            <form action="/admin/product/delete" method="POST" style="display:inline;">
                                <input type="hidden" name="product_id" value="<%= product.product_id %>">
                                <button type="submit" class="btn btn-outline-danger btn-sm"
                                    onclick="return confirm('삭제하시겠습니까?')">삭제</button>
                            </form>
                        </td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>

        <!-- 이벤트 관리 -->
        <div class="section-card" id="events">
            <div class="section-title">이벤트 관리</div>

            <!-- 이벤트 추가 폼 -->
            <form action="/admin/event/add" method="POST" class="row g-2 mb-4">
                <div class="col-md-2">
                    <input type="text" name="title" class="form-control" placeholder="이벤트명" required>
                </div>
                <div class="col-md-3">
                    <input type="text" name="description" class="form-control" placeholder="설명" required>
                </div>
                <div class="col-md-2">
                    <input type="text" name="image" class="form-control" placeholder="이미지 파일명" required>
                </div>
                <div class="col-md-2">
                    <input type="date" name="start_date" class="form-control" required>
                </div>
                <div class="col-md-2">
                    <input type="date" name="end_date" class="form-control" required>
                </div>
                <div class="col-md-1">
                    <button type="submit" class="btn btn-dark btn-sm w-100">추가</button>
                </div>
            </form>

            <!-- 이벤트 목록 -->
            <table class="table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>이벤트명</th>
                        <th>설명</th>
                        <th>이미지</th>
                        <th>시작일</th>
                        <th>종료일</th>
                        <th>관리</th>
                    </tr>
                </thead>
                <tbody>
                    <% events.forEach(event => { %>
                    <tr>
                        <td><%= event.event_id %></td>
                        <td><%= event.title %></td>
                        <td><%= event.description %></td>
                        <td><%= event.image %></td>
                        <td><%= new Date(event.start_date).toLocaleDateString('ko-KR') %></td>
                        <td><%= new Date(event.end_date).toLocaleDateString('ko-KR') %></td>
                        <td>
                            <form action="/admin/event/delete" method="POST" style="display:inline;">
                                <input type="hidden" name="event_id" value="<%= event.event_id %>">
                                <button type="submit" class="btn btn-outline-danger btn-sm"
                                    onclick="return confirm('삭제하시겠습니까?')">삭제</button>
                            </form>
                        </td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>

        <!-- 회원 관리 -->
        <div class="section-card" id="users">
            <div class="section-title">회원 관리</div>
            <table class="table">
                <thead>
                    <tr>
                        <th>번호</th>
                        <th>아이디</th>
                        <th>이름</th>
                        <th>이메일</th>
                        <th>권한</th>
                    </tr>
                </thead>
                <tbody>
                    <% users.forEach(u => { %>
                    <tr>
                        <td><%= u.user_num %></td>
                        <td><%= u.user_id %></td>
                        <td><%= u.name %></td>
                        <td><%= u.email || '-' %></td>
                        <td>
                            <% if (u.role === 'admin') { %>
                                <span class="badge-admin">admin</span>
                            <% } else { %>
                                <span class="badge-user">user</span>
                            <% } %>
                        </td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
