<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= product.product_name %> | Seoyeon Tour</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=Noto+Sans+KR:wght@300;400;500;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Noto Sans KR', sans-serif; }
        .hero {
            background-image: url('/images/<%= product.image %>');
            background-size: cover;
            background-position: center;
            height: 400px;
            position: relative;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .hero::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0; bottom: 0;
            background: rgba(0,0,0,0.5);
        }
        .hero h1 { position: relative; z-index: 1; }
        .nav-link { color: #555 !important; font-size: 0.9rem; }
        .nav-link:hover { color: #000 !important; }
    </style>
</head>
<body>

    <nav class="navbar navbar-expand-lg bg-white shadow-sm fixed-top px-4">
        <a class="navbar-brand fw-bold" href="/">SEOYEON TOUR</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navMenu">
            <ul class="navbar-nav ms-auto gap-2">
                <li class="nav-item"><a class="nav-link" href="/introduce">소개</a></li>
                <li class="nav-item"><a class="nav-link" href="/event">이벤트</a></li>
                <li class="nav-item"><a class="nav-link" href="/honeymoon-europe">허니문-유럽</a></li>
                <li class="nav-item"><a class="nav-link" href="/honeymoon-resort">허니문-휴양지</a></li>
                <li class="nav-item"><a class="nav-link" href="/group">단체여행</a></li>
                <li class="nav-item"><a class="nav-link" href="/package">패키지</a></li>
                <li class="nav-item"><a class="nav-link" href="/reviews">후기</a></li>
                <li class="nav-item"><a class="nav-link" href="/contact">온라인문의</a></li>
                <% if (user) { %>
                <li class="nav-item"><a class="nav-link fw-bold text-dark" href="/mypage"><%= user.name %>님</a></li>
                <li class="nav-item"><a class="nav-link" href="/mypage">마이페이지</a></li>
                <li class="nav-item"><a class="nav-link text-danger" href="/auth/logout">로그아웃</a></li>
                <% } else { %>
                <li class="nav-item"><a class="nav-link" href="/login">로그인</a></li>
                <li class="nav-item"><a class="nav-link" href="/signup-page">회원가입</a></li>
                <% } %>
            </ul>
        </div>
    </nav>

    <div class="hero mt-5">
        <h1 class="text-white fw-light display-4"><%= product.product_name %> · <%= product.destination %></h1>
    </div>

    <div class="bg-dark py-2 px-4">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a href="/" class="text-white text-decoration-none">🏠</a></li>
            <li class="breadcrumb-item"><a href="/<%= product.category %>" class="text-white text-decoration-none"><%= product.category %></a></li>
            <li class="breadcrumb-item text-white-50 active"><%= product.product_name %></li>
        </ol>
    </div>

    <section class="py-5">
        <div class="container py-3">
            <div class="row justify-content-center">
                <div class="col-md-8">
                    <p class="text-muted small mb-1 text-center"><%= product.destination.toUpperCase() %></p>
                    <h2 class="fw-light text-center mb-4"><%= product.description %></h2>
                    <p class="text-muted lh-lg mb-5"><%= product.highlights %></p>

                    <h5 class="fw-medium mb-3">여행 일정</h5>
                    <table class="table table-bordered text-muted small mb-5">
                        <tbody>
                            <% product.schedule.split('\n').forEach((line, i) => { %>
                            <tr>
                                <td class="fw-medium" style="width:80px"><%= (i+1) %>일차</td>
                                <td><%= line.replace(/^\d+일차:\s*/, '') %></td>
                            </tr>
                            <% }) %>
                        </tbody>
                    </table>

                    <h5 class="fw-medium mb-3">포함 사항</h5>
                    <p class="text-muted lh-lg mb-5"><%= product.included %></p>

                    <div class="d-flex justify-content-between align-items-center p-4 bg-light rounded mb-4">
                        <div>
                            <p class="text-muted small mb-1">여행 기간</p>
                            <p class="fw-medium mb-0"><%= product.duration %></p>
                        </div>
                        <div>
                            <p class="text-muted small mb-1">출발 인원</p>
                            <p class="fw-medium mb-0">2인 기준</p>
                        </div>
                        <div>
                            <p class="text-muted small mb-1">여행 금액</p>
                            <p class="fw-medium mb-0 text-danger"><%= Number(product.price).toLocaleString() %>원~</p>
                        </div>
                    </div>
                    <div class="d-grid">
                        <a href="/contact" class="btn btn-dark btn-lg py-3">예약하기</a>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <footer class="py-5 text-center text-muted small border-top">
        <p class="fw-medium text-dark mb-1">SEOYEON TOUR</p>
        <p>대표자: 원서연, 정유진</p>
        <p>Tel: 010-2987-7368 · Email: angelo2001@naver.com</p>
        <p class="mt-3">© 2025 Seoyeon Tour. All rights reserved.</p>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
