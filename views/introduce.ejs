<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>소개 - SEOYEON TOUR</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@300;400;500;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Noto Sans KR', sans-serif;
            background-color: #ffffff;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }
        .navbar { border-bottom: 1px solid #eee; }
        .introduce-wrapper {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            padding-top: 110px;
            padding-bottom: 60px;
        }
        .introduce-container {
            width: 100%;
            max-width: 860px;
            padding: 20px;
        }
        .introduce-title {
            font-size: 2.4rem;
            font-weight: 400;
            color: #4a6fa5;
            text-align: center;
            margin-bottom: 12px;
            letter-spacing: -1px;
        }
        .introduce-subtitle {
            text-align: center;
            color: #888;
            font-size: 0.95rem;
            margin-bottom: 48px;
        }
        .introduce-img-wrap {
            width: 100%;
            border-radius: 12px;
            overflow: hidden;
            box-shadow: 0 8px 32px rgba(74, 111, 165, 0.10);
        }
        .introduce-img-wrap img {
            width: 100%;
            height: auto;
            display: block;
            object-fit: cover;
        }
    </style>
</head>
<body>

    <nav class="navbar navbar-expand-lg bg-white fixed-top px-4">
        <a class="navbar-brand fw-bold text-dark" href="/" style="text-decoration:none;">SEOYEON TOUR</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navMenu">
            <ul class="navbar-nav ms-auto gap-2">
                <li class="nav-item"><a class="nav-link" href="/introduce">소개</a></li>
                <li class="nav-item"><a class="nav-link" href="/event">이벤트</a></li>
                <li class="nav-item"><a class="nav-link" href="/honeymoon-europe">허니문-유럽</a></li>
                <li class="nav-item"><a class="nav-link" href="/honeymoon-resort">허니문-휴양지</a></li>
                <li class="nav-item"><a class="nav-link" href="/group">단체여행</a></li>
                <li class="nav-item"><a class="nav-link" href="/package">패키지</a></li>
                <li class="nav-item"><a class="nav-link" href="/reviews">리뷰</a></li>
                <% if (user) { %>
                    <li class="nav-item">
                        <a class="nav-link fw-bold" href="/mypage" style="color:#4a6fa5;">
                            <%= user.name %> 님
                        </a>
                    </li>
                    <li class="nav-item"><a class="nav-link" href="/auth/logout">로그아웃</a></li>
                <% } else { %>
                    <li class="nav-item"><a class="nav-link" href="/login">로그인</a></li>
                    <li class="nav-item"><a class="nav-link text-primary fw-bold" href="/signup-page">회원가입하기</a></li>
                <% } %>
            </ul>
        </div>
    </nav>

    <div class="introduce-wrapper">
        <div class="introduce-container">
            <h1 class="introduce-title">서연투어 소개</h1>
            <p class="introduce-subtitle">Seoyeon Tour — Crafting Memorable Journeys Since 2010</p>
            <div class="introduce-img-wrap">
                <img src="/images/introduce.png" alt="서연투어 소개 이미지">
            </div>
        </div>
    </div>

    <footer class="py-5 text-center text-muted small border-top bg-white">
        <div class="fw-medium text-dark mb-1">SEOYEON TOUR</div>
        Tel: 010-298-7368 , Email: angelo2001@naver.com<br>
        <div class="mt-3">© 2026 Seoyeon Tour. All rights reserved.</div>
        사업자 대표: 원서연, 정유진
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
