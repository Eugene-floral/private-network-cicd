<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>마이페이지 | Seoyeon Tour</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@300;400;500;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Noto Sans KR', sans-serif; }
        .nav-link { color: #555 !important; font-size: 0.9rem; }
        .nav-link:hover { color: #000 !important; }
        .mypage-header {
            background-color: #1a1a2e;
            height: 200px;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .info-card {
            border: none;
            box-shadow: 0 2px 15px rgba(0,0,0,0.08);
            border-radius: 12px;
        }
    </style>
</head>
<body>

    <nav class="navbar navbar-expand-lg bg-white shadow-sm fixed-top px-4">
        <a class="navbar-brand fw-bold" href="/">SEOYEON TOUR</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navMenu">
            <ul class="navbar-nav ms-auto gap-2">
                <li class="nav-item"><a class="nav-link" href="/introduce">소개</a></li>
                <li class="nav-item"><a class="nav-link" href="/event">이벤트</a></li>
                <li class="nav-item"><a class="nav-link" href="/honeymoon-europe">허니문-유럽</a></li>
                <li class="nav-item"><a class="nav-link" href="/honeymoon-resort">허니문-휴양지</a></li>
                <li class="nav-item"><a class="nav-link" href="/group">단체여행</a></li>
                <li class="nav-item"><a class="nav-link" href="/package">패키지</a></li>
                <li class="nav-item"><a class="nav-link" href="/reviews">후기</a></li>
                <li class="nav-item"><a class="nav-link" href="/contact">온라인문의</a></li>
                <li class="nav-item">
                    <a class="nav-link fw-bold text-dark" href="/mypage"><%= user.name %>님</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link active" href="/mypage">마이페이지</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link text-danger" href="/auth/logout">로그아웃</a>
                </li>
            </ul>
        </div>
    </nav>

    <!-- 헤더 -->
    <div class="mypage-header mt-5">
        <div class="text-center text-white">
            <p class="small mb-1" style="letter-spacing: 4px; opacity: 0.7;">MY PAGE</p>
            <h2 class="fw-light"><%= user.name %>님 안녕하세요</h2>
        </div>
    </div>

    <section class="py-5">
        <div class="container py-3">
            <div class="row g-4">

                <!-- 내 정보 -->
                <div class="col-md-4">
                    <div class="card info-card p-4">
                        <p class="text-muted small mb-3" style="letter-spacing: 2px;">MY INFO</p>
                        <h5 class="fw-medium mb-4">내 정보</h5>
                        <table class="table table-borderless text-muted small">
                            <tr>
                                <td class="fw-medium text-dark">이름</td>
                                <td><%= user.name %></td>
                            </tr>
                            <tr>
                                <td class="fw-medium text-dark">아이디</td>
                                <td><%= user.user_id %></td>
                            </tr>
                            <tr>
                                <td class="fw-medium text-dark">이메일</td>
                                <td><%= user.email %></td>
                            </tr>
                            <tr>
                                <td class="fw-medium text-dark">전화번호</td>
                                <td><%= user.phonenum %></td>
                            </tr>
                            <tr>
                                <td class="fw-medium text-dark">주소</td>
                                <td><%= user.address %></td>
                            </tr>
                        </table>
                        <a href="/auth/logout" class="btn btn-outline-danger btn-sm mt-3">로그아웃</a>
                    </div>
                </div>

                <!-- 결제 내역 -->
                <div class="col-md-8">
                    <div class="card info-card p-4">
                        <p class="text-muted small mb-3" style="letter-spacing: 2px;">MY PAYMENTS</p>
                        <h5 class="fw-medium mb-4">결제 내역</h5>
                        <% if (payments.length > 0) { %>
                            <table class="table text-muted small">
                                <thead>
                                    <tr>
                                        <th>결제일</th>
                                        <th>총 금액</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% payments.forEach(payment => { %>
                                    <tr>
                                        <td><%= new Date(payment.paid_at).toLocaleDateString() %></td>
                                        <td><%= payment.amount ? payment.amount.toLocaleString() : '-' %>원</td>
                                    </tr>
                                    <% }) %>
                                </tbody>
                            </table>
                        <% } else { %>
                            <p class="text-muted text-center py-4">결제 내역이 없습니다.</p>
                        <% } %>
                    </div>
                </div>

            </div>
        </div>
    </section>

    <footer class="py-5 text-center text-muted small border-top">
        <p class="fw-medium text-dark mb-1">SEOYEON TOUR</p>
        <p>대표자: 원서연, 정유진</p>
        <p>Tel: 010-2987-7368 · Email: angelo2001@naver.com</p>
        <p class="mt-3">© 2025 Seoyeon Tour. All rights reserved.</p>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
