<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>주문 | Seoyeon Tour</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@300;400;500;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Noto Sans KR', sans-serif; background: #f8f7f4; }
        .nav-link { color: #555 !important; font-size: 0.9rem; }
        .nav-link:hover { color: #000 !important; }
        .order-card {
            background: #fff;
            border-radius: 16px;
            box-shadow: 0 2px 20px rgba(0,0,0,0.06);
            padding: 32px;
        }
        .section-label {
            font-size: 0.75rem;
            letter-spacing: 3px;
            color: #aaa;
            text-transform: uppercase;
            margin-bottom: 16px;
        }
        .product-img {
            width: 100%;
            height: 200px;
            object-fit: cover;
            border-radius: 12px;
            margin-bottom: 20px;
        }
        .info-row {
            display: flex;
            justify-content: space-between;
            padding: 10px 0;
            border-bottom: 1px solid #f0f0f0;
            font-size: 0.88rem;
        }
        .info-row:last-child { border-bottom: none; }
        .info-row span:first-child { color: #888; }
        .info-row span:last-child { font-weight: 500; }
        .qty-btn {
            width: 32px;
            height: 32px;
            border: 1px solid #ddd;
            background: #fff;
            border-radius: 50%;
            font-size: 1.2rem;
            cursor: pointer;
            line-height: 1;
        }
        .qty-btn:hover { background: #f0f0f0; }
        .total-price {
            font-size: 1.4rem;
            font-weight: 700;
            color: #1a1a2e;
        }
        .btn-pay {
            background: #1a1a2e;
            color: #fff;
            border: none;
            border-radius: 8px;
            padding: 14px;
            font-size: 1rem;
            width: 100%;
            cursor: pointer;
        }
        .btn-pay:hover { background: #2d2d4e; }
    </style>
</head>
<body>

    <nav class="navbar navbar-expand-lg bg-white shadow-sm fixed-top px-4">
        <a class="navbar-brand fw-bold" href="/">SEOYEON TOUR</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navMenu">
            <ul class="navbar-nav ms-auto gap-2">
                <li class="nav-item"><a class="nav-link" href="/introduce">소개</a></li>
                <li class="nav-item"><a class="nav-link" href="/event">이벤트</a></li>
                <li class="nav-item"><a class="nav-link" href="/honeymoon-europe">허니문-유럽</a></li>
                <li class="nav-item"><a class="nav-link" href="/honeymoon-resort">허니문-휴양지</a></li>
                <li class="nav-item"><a class="nav-link" href="/group">단체여행</a></li>
                <li class="nav-item"><a class="nav-link" href="/package">패키지</a></li>
                <li class="nav-item"><a class="nav-link" href="/reviews">후기</a></li>
                <li class="nav-item"><a class="nav-link" href="/contact">온라인문의</a></li>
                <% if (user) { %>
                <li class="nav-item"><a class="nav-link fw-bold text-dark" href="/mypage"><%= user.name %>님</a></li>
                <li class="nav-item"><a class="nav-link" href="/mypage">마이페이지</a></li>
                <li class="nav-item"><a class="nav-link text-danger" href="/auth/logout">로그아웃</a></li>
                <% } else { %>
                <li class="nav-item"><a class="nav-link" href="/login">로그인</a></li>
                <li class="nav-item"><a class="nav-link" href="/signup-page">회원가입</a></li>
                <% } %>
            </ul>
        </div>
    </nav>

    <section class="py-5 mt-5">
        <div class="container py-3" style="max-width: 900px;">
            <div class="row g-4">

                <div class="col-md-5">
                    <div class="order-card">
                        <p class="section-label">상품 정보</p>
                        <img src="/images/<%= product.image %>" class="product-img" alt="<%= product.product_name %>">
                        <div class="info-row">
                            <span>상품명</span>
                            <span><%= product.product_name %></span>
                        </div>
                        <div class="info-row">
                            <span>여행지</span>
                            <span><%= product.destination %></span>
                        </div>
                        <div class="info-row">
                            <span>기간</span>
                            <span><%= product.duration %></span>
                        </div>
                        <div class="info-row">
                            <span>1인 금액</span>
                            <span><%= Number(product.price).toLocaleString() %>원</span>
                        </div>
                    </div>
                </div>

                <div class="col-md-7">
                    <div class="order-card">
                        <p class="section-label">주문 정보</p>

                        <div class="mb-4">
                            <p class="text-muted small mb-2">예약자</p>
                            <p class="fw-medium"><%= user.name %></p>
                        </div>

                        <div class="mb-4">
                            <p class="text-muted small mb-2">인원 선택</p>
                            <div class="d-flex align-items-center gap-3">
                                <button class="qty-btn" id="btn-minus">−</button>
                                <span id="qty" style="font-size:1.1rem; font-weight:500;">1</span>
                                <button class="qty-btn" id="btn-plus">+</button>
                                <span class="text-muted small">명</span>
                            </div>
                        </div>

                        <div class="mb-4 p-3 bg-light rounded">
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="text-muted small">총 결제 금액</span>
                                <span class="total-price" id="totalPrice"><%= Number(product.price).toLocaleString() %>원</span>
                            </div>
                        </div>

                        <button class="btn-pay" id="btn-pay">결제하기</button>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <footer class="py-5 text-center text-muted small border-top">
        <p class="fw-medium text-dark mb-1">SEOYEON TOUR</p>
        <p>대표자: 원서연, 정유진</p>
        <p>Tel: 010-2987-7368 · Email: angelo2001@naver.com</p>
        <p class="mt-3">© 2025 Seoyeon Tour. All rights reserved.</p>
    </footer>

    <script src="https://js.tosspayments.com/v1"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        const price = <%= product.price %>;
        let quantity = 1;

        document.getElementById('btn-minus').onclick = function() {
            if (quantity <= 1) return;
            quantity--;
            document.getElementById('qty').textContent = quantity;
            document.getElementById('totalPrice').textContent = (price * quantity).toLocaleString() + '원';
        };

        document.getElementById('btn-plus').onclick = function() {
            quantity++;
            document.getElementById('qty').textContent = quantity;
            document.getElementById('totalPrice').textContent = (price * quantity).toLocaleString() + '원';
        };

        document.getElementById('btn-pay').onclick = async function() {
            const total = price * quantity;
            const res = await fetch('/order/create', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    product_id: '<%= product.product_id %>',
                    quantity: quantity,
                    total_price: total
                })
            });
            const { order_id } = await res.json();

            const tossPayments = TossPayments('<%= clientKey %>');
            tossPayments.requestPayment('카드', {
                amount: total,
                orderId: order_id,
                orderName: '<%= product.product_name %>',
                customerName: '<%= user.name %>',
                successUrl: window.location.origin + '/order/payment/success',
                failUrl: window.location.origin + '/order/payment/fail'
            });
        };
    </script>
</body>
</html>
