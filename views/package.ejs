<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>패키지 | Seoyeon Tour</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=Noto+Sans+KR:wght@300;400;500;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Noto Sans KR', sans-serif; }
        .page-header {
            background-image: url('/images/mypagewall.jpg');
            background-size: cover;
            background-position: center;
            height: 350px;
            position: relative;
            display: flex;
            padding-left: 30px;
            padding-top: 50px;
            align-items: flex-start;
            justify-content: flex-start;
            overflow: hidden;
        }
        .page-header::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0; bottom: 0;
            background: linear-gradient(
                to right,
                rgba(0,0,0,0.7) 0%,
                rgba(0,0,0,0.2) 60%,
                rgba(0,0,0,0) 100%
            );
            z-index: 0;
        }
        .page-header h2 {
            position: relative;
            z-index: 1;
            font-family: 'Playfair Display', serif;
            font-size: 3.5rem;
            letter-spacing: 4px;
            animation: slideUp 1s ease forwards;
        }
        .page-header p {
            position: relative;
            z-index: 1;
            animation: slideUp 1.3s ease forwards;
        }
        @keyframes slideUp {
            from { opacity: 0; transform: translateY(30px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .nav-link { color: #555 !important; font-size: 0.9rem; }
        .nav-link:hover { color: #000 !important; }
        .empty-box {
            background: #f8f7f4;
            border-radius: 16px;
            padding: 80px 40px;
            text-align: center;
        }
    </style>
</head>
<body>

    <nav class="navbar navbar-expand-lg bg-white shadow-sm fixed-top px-4">
        <a class="navbar-brand fw-bold" href="/">SEOYEON TOUR</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navMenu">
            <ul class="navbar-nav ms-auto gap-2">
                <li class="nav-item"><a class="nav-link" href="/introduce">소개</a></li>
                <li class="nav-item"><a class="nav-link" href="/event">이벤트</a></li>
                <li class="nav-item"><a class="nav-link" href="/honeymoon-europe">허니문-유럽</a></li>
                <li class="nav-item"><a class="nav-link" href="/honeymoon-resort">허니문-휴양지</a></li>
                <li class="nav-item"><a class="nav-link" href="/group">단체여행</a></li>
                <li class="nav-item"><a class="nav-link active fw-bold text-dark" href="/package">패키지</a></li>
                <li class="nav-item"><a class="nav-link" href="/reviews">후기</a></li>                <% if (user) { %>
                <li class="nav-item"><a class="nav-link fw-bold text-dark" href="/mypage"><%= user.name %>님</a></li>
                <li class="nav-item"><a class="nav-link" href="/mypage">마이페이지</a></li>
                <li class="nav-item"><a class="nav-link text-danger" href="/auth/logout">로그아웃</a></li>
                <% } else { %>
                <li class="nav-item"><a class="nav-link" href="/login">로그인</a></li>
                <li class="nav-item"><a class="nav-link" href="/signup-page">회원가입</a></li>
                <% } %>
            </ul>
        </div>
    </nav>

    <div class="page-header mt-5">
        <div style="position: relative; z-index: 1;">
            <p class="text-white small mb-2" style="letter-spacing: 6px; opacity: 0.8;">SEOYEON TOUR</p>
            <h2 class="text-white fw-normal mb-0">Package Tour</h2>
        </div>
    </div>

    <div class="bg-dark py-2 px-4">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a href="/" class="text-white text-decoration-none">🏠</a></li>
            <li class="breadcrumb-item text-white-50 active">패키지</li>
        </ol>
    </div>

    <section class="py-5">
        <div class="container py-3">
            <% if (products.length > 0) { %>
            <div class="row g-4 justify-content-center">
                <% products.forEach(product => { %>
                <div class="col-md-4">
                    <div class="card shadow-sm">
                        <img src="/images/<%= product.image %>" class="card-img-top" alt="<%= product.product_name %>">
                        <div class="card-body text-center p-4">
                            <p class="text-muted small mb-1"><%= product.destination %></p>
                            <h5 class="fw-medium mb-1"><%= product.product_name %></h5>
                            <p class="text-muted small mb-3"><%= product.duration %> · <%= Number(product.price).toLocaleString() %>원</p>
                            <a href="/product/<%= product.product_id %>" class="btn btn-outline-dark btn-sm px-4">자세히 보기</a>
                        </div>
                    </div>
                </div>
                <% }) %>
            </div>
            <% } else { %>
            <div class="empty-box">
                <p class="text-muted mb-2" style="font-size: 0.9rem;">현재 준비 중인 패키지 상품입니다.</p>
                <p class="text-muted small">빠른 시일 내에 새로운 상품으로 찾아뵙겠습니다.</p>
                <a href="/contact" class="btn btn-outline-dark btn-sm mt-3 px-4">문의하기</a>
            </div>
            <% } %>
        </div>
    </section>

    <footer class="py-5 text-center text-muted small border-top">
        <p class="fw-medium text-dark mb-1">SEOYEON TOUR</p>
        <p>대표자: 원서연, 정유진</p>
        <p>Tel: 010-2987-7368 · Email: angelo2001@naver.com</p>
        <p class="mt-3">© 2025 Seoyeon Tour. All rights reserved.</p>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
