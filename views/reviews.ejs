<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>후기 | Seoyeon Tour</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=Noto+Sans+KR:wght@300;400;500;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Noto Sans KR', sans-serif; }
        .page-header {
            background-image: url('/images/reviews.jpg');
            background-size: cover;
            background-position: center;
            height: 350px;
            position: relative;
            display: flex;
            padding-left: 30px;
            padding-top: 50px;
            align-items: flex-start;
            justify-content: flex-start;
            overflow: hidden;
        }
        .page-header::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0; bottom: 0;
            background: linear-gradient(
                to right,
                rgba(0,0,0,0.7) 0%,
                rgba(0,0,0,0.2) 60%,
                rgba(0,0,0,0) 100%
            );
            z-index: 0;
        }
        .page-header h2 {
            position: relative;
            z-index: 1;
            font-family: 'Playfair Display', serif;
            font-size: 3.5rem;
            letter-spacing: 4px;
            animation: slideUp 1s ease forwards;
        }
        .page-header p {
            position: relative;
            z-index: 1;
            animation: slideUp 1.3s ease forwards;
        }
        @keyframes slideUp {
            from { opacity: 0; transform: translateY(30px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .nav-link { color: #555 !important; font-size: 0.9rem; }
        .nav-link:hover { color: #000 !important; }
        .review-card {
            background: #fff;
            border-radius: 12px;
            padding: 24px;
            margin-bottom: 16px;
            box-shadow: 0 2px 12px rgba(0,0,0,0.06);
        }
        .star { color: #f4c542; font-size: 1rem; }
        .btn-write {
            background: #1a1a2e;
            color: #fff;
            border: none;
            border-radius: 8px;
            padding: 10px 24px;
            font-size: 0.88rem;
            cursor: pointer;
        }
        .btn-write:hover { background: #2d2d4e; color: #fff; }
        .modal-overlay {
            display: none;
            position: fixed;
            top: 0; left: 0; right: 0; bottom: 0;
            background: rgba(0,0,0,0.5);
            z-index: 1000;
            align-items: center;
            justify-content: center;
        }
        .modal-overlay.active { display: flex; }
        .modal-box {
            background: #fff;
            border-radius: 16px;
            padding: 36px;
            width: 480px;
            max-width: 90%;
        }
        .star-select { font-size: 1.8rem; cursor: pointer; }
        .star-select span { color: #ddd; }
        .star-select span.active { color: #f4c542; }
    </style>
</head>
<body>

    <nav class="navbar navbar-expand-lg bg-white shadow-sm fixed-top px-4">
        <a class="navbar-brand fw-bold" href="/">SEOYEON TOUR</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navMenu">
            <ul class="navbar-nav ms-auto gap-2">
                <li class="nav-item"><a class="nav-link" href="/introduce">소개</a></li>
                <li class="nav-item"><a class="nav-link" href="/event">이벤트</a></li>
                <li class="nav-item"><a class="nav-link" href="/honeymoon-europe">허니문-유럽</a></li>
                <li class="nav-item"><a class="nav-link" href="/honeymoon-resort">허니문-휴양지</a></li>
                <li class="nav-item"><a class="nav-link" href="/group">단체여행</a></li>
                <li class="nav-item"><a class="nav-link" href="/package">패키지</a></li>
                <li class="nav-item"><a class="nav-link active fw-bold text-dark" href="/reviews">후기</a></li>
                <li class="nav-item"><a class="nav-link" href="/contact">온라인문의</a></li>
                <% if (user) { %>
                <li class="nav-item"><a class="nav-link fw-bold text-dark" href="/mypage"><%= user.name %>님</a></li>
                <li class="nav-item"><a class="nav-link" href="/mypage">마이페이지</a></li>
                <li class="nav-item"><a class="nav-link text-danger" href="/auth/logout">로그아웃</a></li>
                <% } else { %>
                <li class="nav-item"><a class="nav-link" href="/login">로그인</a></li>
                <li class="nav-item"><a class="nav-link" href="/signup-page">회원가입</a></li>
                <% } %>
            </ul>
        </div>
    </nav>

    <div class="page-header mt-5">
        <div style="position: relative; z-index: 1;">
            <p class="text-white small mb-2" style="letter-spacing: 6px; opacity: 0.8;">SEOYEON TOUR</p>
            <h2 class="text-white fw-normal mb-0">Reviews</h2>
        </div>
    </div>

    <div class="bg-dark py-2 px-4">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a href="/" class="text-white text-decoration-none">🏠</a></li>
            <li class="breadcrumb-item text-white-50 active">후기</li>
        </ol>
    </div>

    <section class="py-5">
        <div class="container py-3" style="max-width: 800px;">

            <div class="d-flex justify-content-between align-items-center mb-4">
                <h5 class="fw-medium mb-0">여행 후기 (<%= reviews.length %>)</h5>
                <% if (user && myPayments.length > 0) { %>
                <button class="btn-write" id="openModal">후기 작성</button>
                <% } %>
            </div>

            <% if (reviews.length > 0) { %>
                <% reviews.forEach(review => { %>
                <div class="review-card">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <div>
                            <span class="fw-medium me-2"><%= review.name %></span>
                            <span class="text-muted small"><%= review.product_name %></span>
                        </div>
                        <span class="text-muted small"><%= new Date(review.reviewed_at).toLocaleDateString('ko-KR') %></span>
                    </div>
                    <div class="star mb-2">
                        <% for(let i = 1; i <= 5; i++) { %>
                            <% if(i <= review.rate) { %>★<% } else { %>☆<% } %>
                        <% } %>
                    </div>
                    <p class="text-muted small mb-0"><%= review.contents %></p>
                </div>
                <% }) %>
            <% } else { %>
                <p class="text-center text-muted py-5">아직 작성된 후기가 없습니다.</p>
            <% } %>

        </div>
    </section>

    <!-- 후기 작성 모달 -->
    <% if (user && myPayments.length > 0) { %>
    <div class="modal-overlay" id="modalOverlay">
        <div class="modal-box">
            <h5 class="fw-medium mb-4">후기 작성</h5>
            <form action="/reviews/write" method="POST">
                <div class="mb-3">
                    <label class="form-label text-muted small">여행 상품 선택</label>
                    <select name="payment_id" class="form-select form-select-sm" required>
                        <% myPayments.forEach(p => { %>
                        <option value="<%= p.payment_id %>"><%= p.product_name %></option>
                        <% }) %>
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label text-muted small">별점</label>
                    <div class="star-select" id="starSelect">
                        <span data-val="1">★</span>
                        <span data-val="2">★</span>
                        <span data-val="3">★</span>
                        <span data-val="4">★</span>
                        <span data-val="5">★</span>
                    </div>
                    <input type="hidden" name="rate" id="rateInput" value="5">
                </div>
                <div class="mb-4">
                    <label class="form-label text-muted small">후기 내용</label>
                    <textarea name="contents" class="form-control" rows="4" required placeholder="여행 후기를 작성해주세요."></textarea>
                </div>
                <div class="d-flex gap-2">
                    <button type="submit" class="btn-write flex-grow-1">등록</button>
                    <button type="button" class="btn btn-outline-secondary btn-sm flex-grow-1" id="closeModal">취소</button>
                </div>
            </form>
        </div>
    </div>
    <% } %>

    <footer class="py-5 text-center text-muted small border-top">
        <p class="fw-medium text-dark mb-1">SEOYEON TOUR</p>
        <p>대표자: 원서연, 정유진</p>
        <p>Tel: 010-2987-7368 · Email: angelo2001@naver.com</p>
        <p class="mt-3">© 2025 Seoyeon Tour. All rights reserved.</p>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        const openBtn = document.getElementById('openModal');
        const closeBtn = document.getElementById('closeModal');
        const overlay = document.getElementById('modalOverlay');

        if (openBtn) openBtn.onclick = () => overlay.classList.add('active');
        if (closeBtn) closeBtn.onclick = () => overlay.classList.remove('active');
        overlay && overlay.addEventListener('click', (e) => {
            if (e.target === overlay) overlay.classList.remove('active');
        });

        const stars = document.querySelectorAll('#starSelect span');
        stars.forEach(star => {
            star.onclick = function() {
                const val = parseInt(this.dataset.val);
                document.getElementById('rateInput').value = val;
                stars.forEach((s, i) => {
                    s.classList.toggle('active', i < val);
                });
            };
        });

        document.querySelectorAll('#starSelect span').forEach((s, i) => {
            if (i < 5) s.classList.add('active');
        });
    </script>
</body>
</html>
